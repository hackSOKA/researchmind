# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_KEY=your_azure_search_key
